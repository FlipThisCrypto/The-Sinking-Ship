  "quotas": [
    {
      "id": "q_the_torn",
      "type": "quota",
      "name": "the_torn",
      "count": 44,
      "assign": {
        "layer": "hat",
        "trait": "The Torn"
      },
      "mechanism": "44 global mint indices in [1, 44400] are pre-committed at commit time, derived from HMAC-SHA256(salt, 'the-torn-slots-v1'). An NFT whose global mint index is in the set has its hat overridden to The Torn. Under The Scuttling (undersell), unminted slots simply never occur, so the realized count can be < 44 — see ADR-0003 and open question OQ-3.",
      "source": "spec 3: Halo+Horns appear together on exactly 44 NFTs ('The Torn')"
    }
  ],
  "rules": [
    {
      "id": "r_mythic_forced_aura",
      "type": "forced_aura",
      "if_tier": "mythic",
      "then": {
        "layer": "aura",
        "exclude_traits": [
          "None"
        ]
      },
      "source": "spec 4.1: Mythic = contains >=1 Mythic-bucket trait + forced aura"
    }
  ]
