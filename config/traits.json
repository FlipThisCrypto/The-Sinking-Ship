  "exclusions": [
    {
      "id": "x_diver_helmet_mouth",
      "type": "require",
      "if": {
        "layer": "hat",
        "trait": "Diver Helmet"
      },
      "then": {
        "layer": "mouth",
        "traits": [
          "None"
        ]
      },
      "source": "spec 3: Diver Helmet excludes ALL mouth items"
    },
    {
      "id": "x_diver_helmet_hats",
      "type": "note",
      "note": "Diver Helmet excludes all other hats — trivially enforced: hat is a single-select layer",
      "source": "spec 3"
    },
    {
      "id": "x_ghost_body_burning",
      "type": "exclude",
      "if": {
        "layer": "body",
        "trait": "Ghost"
      },
      "then": {
        "layer": "ship_condition",
        "traits": [
          "Burning"
        ]
      },
      "source": "spec 3: Ghost body never pairs with Burning condition"
    },
    {
      "id": "x_fully_underwater_sea",
      "type": "require",
      "if": {
        "layer": "ship_condition",
        "trait": "Fully Underwater"
      },
      "then": {
        "layer": "sea",
        "traits": [
          "Abyss",
          "Bioluminescent",
          "Black Sea"
        ]
      },
      "source": "spec 3: Fully Underwater only pairs with Abyss, Bioluminescent, or Black Sea"
    },
    {
      "id": "x_submarine_pose",
      "type": "exclude",
      "if": {
        "layer": "ship_class",
        "trait": "Submarine"
      },
      "then": {
        "layer": "pose",
        "traits": [
          "On Bow"
        ]
      },
      "source": "spec 3: Submarine excludes On Bow pose"
    },
    {
      "id": "x_submarine_condition",
      "type": "exclude",
      "if": {
        "layer": "ship_class",
        "trait": "Submarine"
      },
      "then": {
        "layer": "ship_condition",
        "traits": [
          "Half Sunk",
          "Listing"
        ]
      },
      "source": "spec 3: subs don't list — they're either fine or gone"
    },
    {
      "id": "x_ark_weather",
      "type": "require_any",
      "if": {
        "layer": "ship_class",
        "trait": "The Ark"
      },
      "then": {
        "any_of": [
          {
            "layer": "sea",
            "traits": [
              "Storm Swell",
              "Whirlpool"
            ]
          },
          {
            "layer": "sky",
            "traits": [
              "Heavy Rain"
            ]
          }
        ]
      },
      "source": "spec 3: The Ark only appears with Storm Swell, Heavy Rain, or Whirlpool"
    },
    {
      "id": "x_halo_horns",
      "type": "note",
      "note": "Halo excludes Horns — trivially enforced by single-select hat layer; the 44 exceptions are 'The Torn' quota below",
      "source": "spec 3"
    },
    {
      "id": "x_mythic_combo_gate",
      "type": "combo_gate",
      "combo": [
        {
          "layer": "sky",
          "trait": "Blood Moon"
        },
        {
          "layer": "ship_class",
          "trait": "Ghost Ship"
        },
        {
          "layer": "scene_element",
          "trait": "Skeleton Crew"
        }
      ],
      "allowed_only_if_tier_at_least": "mythic",
      "source": "spec 3: Blood Moon + Ghost Ship + Skeleton Crew allowed together only in Mythic rolls"
    }
  ],
