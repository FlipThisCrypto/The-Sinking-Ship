{
  "$schema": "./schemas/palette.schema.json",
  "config_name": "palette",
  "version": "1.0.0",
  "spec_reference": "sinking-ship-master-spec.md Section 7 (palette discipline)",
  "notes": [
    "One 32-color master palette; every sprite snaps to it. Six 12-color zone sub-palettes (subsets of the master); background layers (sky, sea) snap to the NFT's zone sub-palette.",
    "Greens anchored on the early Tom Bepe reference art (docs/art-reference/): bepe_green face, olive/mustard workwear.",
    "This is a working palette proposal — swap values freely before final art; render_engine and validators read only this file."
  ],
  "master": [
    {"name": "ink_black",     "hex": "#0d0d1a"},
    {"name": "dark_slate",    "hex": "#2a2a3a"},
    {"name": "slate",         "hex": "#55556b"},
    {"name": "gray",          "hex": "#8a8a9e"},
    {"name": "light_gray",    "hex": "#c8c8d4"},
    {"name": "bone_white",    "hex": "#f2f2ef"},
    {"name": "midnight",      "hex": "#0a1a33"},
    {"name": "deep_navy",     "hex": "#12294d"},
    {"name": "navy",          "hex": "#1d3f73"},
    {"name": "sea_blue",      "hex": "#2f5d99"},
    {"name": "sky_blue",      "hex": "#4d84bf"},
    {"name": "pale_blue",     "hex": "#86b8e0"},
    {"name": "deep_teal",     "hex": "#0f3d3d"},
    {"name": "teal",          "hex": "#17665c"},
    {"name": "seafoam",       "hex": "#26a68c"},
    {"name": "chia_green",    "hex": "#39d98f"},
    {"name": "kelp_green",    "hex": "#1f7a33"},
    {"name": "bepe_green",    "hex": "#74cc44"},
    {"name": "light_green",   "hex": "#a8e063"},
    {"name": "olive",         "hex": "#6b6b2a"},
    {"name": "mustard",       "hex": "#b3a12e"},
    {"name": "gold_sand",     "hex": "#e0c94d"},
    {"name": "rust_red",      "hex": "#8c2f2f"},
    {"name": "ember_orange",  "hex": "#cc5833"},
    {"name": "sunset_orange", "hex": "#e08033"},
    {"name": "peach",         "hex": "#f2b263"},
    {"name": "sand",          "hex": "#f2d5a0"},
    {"name": "deep_violet",   "hex": "#33194d"},
    {"name": "violet",        "hex": "#5c2e8c"},
    {"name": "amethyst",      "hex": "#8c53c6"},
    {"name": "lavender",      "hex": "#c39be0"},
    {"name": "signal_yellow", "hex": "#e6e64d"}
  ],
  "zones": {
    "surface":  ["bone_white", "light_gray", "gray", "slate", "pale_blue", "sky_blue",
                 "sea_blue", "navy", "sand", "peach", "sunset_orange", "signal_yellow"],
    "sunlight": ["pale_blue", "sky_blue", "sea_blue", "navy", "seafoam", "chia_green",
                 "light_green", "bepe_green", "gold_sand", "bone_white", "teal", "mustard"],
    "twilight": ["midnight", "deep_navy", "navy", "sea_blue", "deep_violet", "violet",
                 "amethyst", "lavender", "slate", "deep_teal", "teal", "gray"],
    "midnight": ["ink_black", "midnight", "deep_navy", "navy", "dark_slate", "slate",
                 "deep_teal", "teal", "seafoam", "chia_green", "deep_violet", "violet"],
    "abyssal":  ["ink_black", "midnight", "dark_slate", "slate", "gray", "deep_navy",
                 "deep_teal", "rust_red", "ember_orange", "olive", "mustard", "gold_sand"],
    "hadal":    ["ink_black", "midnight", "dark_slate", "deep_violet", "violet", "amethyst",
                 "chia_green", "seafoam", "gold_sand", "signal_yellow", "bone_white", "deep_teal"]
  },
  "background_layers": ["sky", "sea"]
}
