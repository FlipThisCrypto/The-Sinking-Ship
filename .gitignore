# Output artifacts — never committed
output/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Secrets — the mint salt must NEVER be committed
*.salt
secrets/
.env
.env.*

# Local Claude Code settings (machine-specific; may hold absolute paths)
.claude/settings.local.json

# OS / editor noise
Thumbs.db
.DS_Store
*.swp
.idea/
.vscode/

# Windows shortcut used locally to reach the skills library
*.lnk

# Owner-supplied high-res source art (multi-MB). Only the web/marketplace
# derivatives under site/assets/brand/ (built by scripts/build_brand_assets.py)
# are committed; keep the originals local (or in a bucket/IPFS per ADR-0001).
/banner.png
/banner1.png
/icon.png
